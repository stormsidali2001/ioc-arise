{
  "source": "src",
  "output": "src/di/container.gen.ts",
  "exclude": [
    "node_modules",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/di/**",
    "**/stores/**",
    "**/events/**",
    "**/Sqlite*.ts",
    "**/Dexie*.ts"
  ],
  "modules": {
    "VocabularyModule": [
      "**/domain/vocabulary/**",
      "**/application/vocabulary/**",
      "**/infra/persistence/vocabulary/**",
      "**/infra/persistence/source/**"
    ],
    "ReviewModule": [
      "**/domain/review/**",
      "**/application/review/**",
      "**/infra/persistence/review/**",
      "**/infra/services/**"
    ],
    "SharedModule": [
      "**/application/shared/**",
      "**/infra/event-bus/**",
      "**/infra/shared/**"
    ],
    "NotificationModule": [
      "**/application/notifications/**",
      "**/infra/notifications/**"
    ],
    "StatisticsModule": ["**/application/statistics/**", "**/infra/statistics/**"]
  }
}
